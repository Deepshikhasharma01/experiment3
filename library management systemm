  },
  container: {
    maxWidth: "700px",
    margin: "0 auto",
    padding: "40px 20px",
  },
  heading: {
    textAlign: "center",
    marginBottom: "30px",
    color: "#111",
  },
  card: {
    background: "#eaeaea",
    padding: "20px",
    marginBottom: "20px",
    borderRadius: "10px",
    boxShadow: "0 3px 8px rgba(0,0,0,0.1)",
  },
  cardHeader: {
    display: "flex",
    alignItems: "center",
    gap: "12px",
    marginBottom: "10px",
  },
  cardName: {
    margin: 0,
    fontSize: "18px",
    color: "#111",
  },
  badge: {
    fontSize: "11px",
    fontWeight: "bold",
    padding: "3px 10px",
    borderRadius: "999px",
    letterSpacing: "0.05em",
  },
